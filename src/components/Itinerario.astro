---
// Itinerario.astro
---

<section class="itin-seccion">

  <!-- SEPARADOR FLORAL -->
  <img src="/imagenes/flor.png" alt="" class="separador-flor" />

  <!-- TÍTULO -->
  <p class="font-crimson titulo-itin">ITINERARIO</p>
  <div class="separador-line"></div>

  <!-- TIMELINE CENTRADO -->
  <div class="timeline" id="timeline-itin">

    <div class="evento">
      <span class="font-crimson ev-hora">20:00 hrs</span>
      <div class="punto-wrap"><div class="punto"></div></div>
      <span class="font-crimson ev-nombre">Ingreso de invitados</span>
    </div>

    <div class="evento">
      <span class="font-crimson ev-hora">22:00 hrs</span>
      <div class="punto-wrap"><div class="punto"></div></div>
      <span class="font-crimson ev-nombre">Entrada especial</span>
    </div>

    <div class="evento">
      <span class="font-crimson ev-hora">22:30 hrs</span>
      <div class="punto-wrap"><div class="punto"></div></div>
      <span class="font-crimson ev-nombre">Baile principal</span>
    </div>

    <div class="evento">
      <span class="font-crimson ev-hora">23:00 hrs</span>
      <div class="punto-wrap"><div class="punto"></div></div>
      <span class="font-crimson ev-nombre">Cena</span>
    </div>

    <div class="evento">
      <span class="font-crimson ev-hora">23:30 hrs</span>
      <div class="punto-wrap"><div class="punto"></div></div>
      <span class="font-crimson ev-nombre">Bar abierto</span>
    </div>

    <div class="evento">
      <span class="font-crimson ev-hora">23:55 hrs</span>
      <div class="punto-wrap"><div class="punto"></div></div>
      <span class="font-crimson ev-nombre">Pastel</span>
    </div>

    <div class="evento">
      <span class="font-crimson ev-hora">00:10 hrs</span>
      <div class="punto-wrap"><div class="punto"></div></div>
      <span class="font-crimson ev-nombre">Fiesta y concurso a la mejor pareja de baile</span>
    </div>

    <div class="evento">
      <span class="font-crimson ev-hora">01:30 hrs</span>
      <div class="punto-wrap"><div class="punto"></div></div>
      <span class="font-crimson ev-nombre">Show de Hora Loca, premios sorpresa y diversión</span>
    </div>

  </div>

</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  if (typeof window !== "undefined") {
    document.addEventListener("DOMContentLoaded", () => {
      gsap.set(".evento", { opacity: 0, y: 16 });

      ScrollTrigger.create({
        trigger: "#timeline-itin",
        start: "top 88%",
        onEnter: () => {
          gsap.to(".evento", {
            opacity: 1,
            y: 0,
            duration: 0.55,
            ease: "power2.out",
            stagger: 0.09,
          });
        },
        onLeaveBack: () => {
          gsap.set(".evento", { opacity: 0, y: 16 });
        },
      });
    });
  }
</script>

<style>
  .itin-seccion {
    width: 100%;
    padding: 0 24px 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }

  .separador-flor {
    width: clamp(140px, 55vw, 220px);
    height: auto;
    opacity: 0.85;
  }

  .titulo-itin {
    font-size: clamp(0.9rem, 3.5vw, 1.1rem);
    color: #C8102E;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin: 0;
  }

  .separador-line {
    width: 50px;
    height: 1.5px;
    background: #C8102E;
    border-radius: 2px;
  }

  /* ─── TIMELINE ─── */
  .timeline {
    width: 100%;
    max-width: 300px;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  /* línea vertical central */
  .timeline::before {
    content: "";
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    top: 8px;
    bottom: 8px;
    width: 1.5px;
    background: rgba(200, 16, 46, 0.2);
    border-radius: 2px;
  }

  .evento {
    display: grid;
    grid-template-columns: 1fr 24px 1fr;
    align-items: center;
    gap: 8px;
    padding: 9px 0;
    position: relative;
  }

  .punto-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1;
  }

  .punto {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: #C8102E;
    border: 2px solid rgba(255, 252, 250, 0.95);
    box-shadow: 0 0 0 1.5px #C8102E;
    flex-shrink: 0;
  }

  .ev-hora {
    font-size: clamp(0.72rem, 2.6vw, 0.84rem);
    color: #C8102E;
    letter-spacing: 0.04em;
    text-align: right;
    line-height: 1.3;
  }

  .ev-nombre {
    font-size: clamp(0.8rem, 3vw, 0.92rem);
    color: #1a1a1a;
    line-height: 1.3;
    text-align: left;
  }
</style>
