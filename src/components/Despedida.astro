---
// Despedida.astro
---

<section class="despedida-seccion">
  <div class="contenido" id="card-despedida">

    <!-- SEPARADOR FLORAL -->
    <img src="/imagenes/flor.png" alt="" class="separador-flor" />

    <!-- TÍTULO -->
    <p class="font-crimson titulo-desp">CONFIRMAR ASISTENCIA</p>
    <div class="separador"></div>

    <!-- MENSAJE -->
    <p class="mensaje-texto">
      Sería un honor contar con tu presencia en este día tan especial.
      Por favor confirma tu asistencia antes del evento.
    </p>

    <!-- BOTÓN WHATSAPP -->
    <a
      href="https://wa.me/59168820808?text=Hola%2C%20confirmo%20mi%20asistencia%20a%20los%20XV%20a%C3%B1os%20de%20Axel%20Stif%20el%20s%C3%A1bado%208%20de%20agosto%20de%202026.%20%C2%A1Nos%20vemos%20pronto!"
      target="_blank"
      rel="noopener noreferrer"
      class="boton-whatsapp"
      id="boton-confirmar"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="wa-icon">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      <span class="font-crimson boton-texto">Confirmar Asistencia</span>
    </a>

    <!-- NOTA FINAL -->
    <p class="nota-final font-crimson">
      Axel Stif · Sábado 8 de Agosto 2026
    </p>

  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  if (typeof window !== "undefined") {
    document.addEventListener("DOMContentLoaded", () => {
      gsap.set("#card-despedida", { opacity: 0, y: 30 });

      ScrollTrigger.create({
        trigger: "#card-despedida",
        start: "top 90%",
        onEnter: () => {
          gsap.to("#card-despedida", { opacity: 1, y: 0, duration: 1, ease: "power2.out" });
        },
        onLeaveBack: () => {
          gsap.set("#card-despedida", { opacity: 0, y: 30 });
        },
      });
    });
  }
</script>

<style>
  .despedida-seccion {
    width: 100%;
    padding: 0 24px 60px;
    display: flex;
    justify-content: center;
  }

  .contenido {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
    max-width: 320px;
    width: 100%;
  }

  .separador-flor {
    width: clamp(140px, 55vw, 220px);
    height: auto;
    opacity: 0.85;
  }

  .titulo-desp {
    font-size: clamp(0.9rem, 3.5vw, 1.1rem);
    color: #C8102E;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin: 0;
  }

  .separador {
    width: 50px;
    height: 1.5px;
    background: #C8102E;
    border-radius: 2px;
  }

  .mensaje-texto {
    font-size: clamp(0.88rem, 3.5vw, 1.05rem);
    color: #1a1a1a;
    line-height: 1.7;
    font-style: italic;
    margin: 0;
    padding: 0 28px;
  }

  .boton-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 28px;
    border-radius: 50px;
    background: #C8102E;
    text-decoration: none;
    transition: background 0.25s ease, transform 0.2s ease;
    box-shadow: 0 4px 16px rgba(200, 16, 46, 0.35);
  }

  .boton-whatsapp:hover {
    background: #9b0020;
    transform: translateY(-2px);
    box-shadow: 0 6px 22px rgba(200, 16, 46, 0.5);
  }

  .wa-icon {
    width: 22px;
    height: 22px;
    color: #ffffff;
    flex-shrink: 0;
  }

  .boton-texto {
    font-size: clamp(0.9rem, 3.5vw, 1.05rem);
    color: #ffffff;
    letter-spacing: 0.05em;
  }

  .nota-final {
    font-size: clamp(0.78rem, 2.8vw, 0.9rem);
    color: #888;
    letter-spacing: 0.08em;
    margin: 0;
  }
</style>
